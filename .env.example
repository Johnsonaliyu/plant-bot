# Get a free API key at https://my.plantnet.org/
PLANTNET_API_KEY=your_plantnet_api_key_here

# Which PlantNet project/flora to match against.
# "all" works globally. Other options: k-world-flora, weurope, canada, etc.
PLANTNET_PROJECT=all

# Groq API key (primary) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Nvidia NIM API key (fallback) - https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Your WhatsApp number for pairing-code login, in international format, digits only
# e.g. 2348012345678 (no +, no spaces, no leading zero after country code)
WHATSAPP_PHONE_NUMBER=2348012345678
